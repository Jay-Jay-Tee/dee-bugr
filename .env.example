# DEE-bugr environment variables

# Groq API key for AI explanations
# Get a free key from https://console.groq.com
DEE_BUGR_GROQ_KEY= API_KEY_HERE

# (Optional) AI provider mode
# Set to "local" to use Ollama instead of Groq (must have Ollama installed)
# Leave unset or set to "groq" to use Groq (default)
DEE_BUGR_AI_MODE=groq
